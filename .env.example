# Neon database URL for the server-side sync worker and one-off scripts.
# The browser app does NOT see this — the browser calls Firebase Callable
# Functions, which hold the real DB creds (set via
# `firebase functions:secrets:set DATABASE_URL`). See DEPLOY.md.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Set to 1 when running `firebase emulators:start` so the browser routes
# Callable Function calls to the local emulator on :5001.
# VITE_FUNCTIONS_EMULATOR=1
